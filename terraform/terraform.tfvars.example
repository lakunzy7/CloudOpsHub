project_id         = "expandox-cloudehub"
project_name       = "Expandox-Cloudehub"
project_number     = "828485768677"
region             = "us-central1"
zone               = "us-central1-a"
environment        = "dev"
instance_type      = "e2-medium"
db_password        = "<from-secret-manager>"  # Set via TF_VAR_db_password or use environment-specific tfvars
grafana_password   = "<from-github-secret>"   # Overridden by GitHub Actions secret
github_repo        = "lakunzy7/CloudOpsHub"
github_owner       = "lakunzy7"
allowed_origins    = ["*"]
alert_email        = "alerts@example.com"
domain_name        = ""  # Set to "app.example.com" to enable DNS + SSL
app_subnet_cidr    = "10.0.1.0/24"
