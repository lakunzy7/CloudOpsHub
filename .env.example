# ── Application ──
PORT=8080
NODE_ENV=development

# ── Database ──
# For local dev with 'docker compose --profile local up':
DB_ROOT_PASSWORD=devpassword
DB_PASSWORD=devpassword
DATABASE_URL=mysql://appuser:devpassword@database:3306/bookstore

# For Cloud SQL (production/staging/dev on GCP):
# DATABASE_URL=mysql://appuser:PASSWORD@<cloud-sql-private-ip>:3306/bookstore

# ── AWS ECR (CI/CD) ──
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# ── ArgoCD (CD pipeline) ──
ARGOCD_SERVER=https://argocd.example.com
ARGOCD_AUTH_TOKEN=your-token-here

# ── Grafana ──
GRAFANA_PASSWORD=admin
