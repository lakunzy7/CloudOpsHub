# CloudOpsHub — Staging Environment
# Copy to staging.tfvars and fill in values before deploying.

project_id               = "YOUR_PROJECT_ID"
project_name             = "cloudopshub"
environment              = "staging"
region                   = "us-central1"
zone                     = "us-central1-a"
instance_type            = "e2-medium"
github_repo              = "YOUR_USERNAME/CloudOpsHub"
create_artifact_registry = false  # Registry already created by first env

# Generate with: openssl rand -base64 16
db_password              = "CHANGE_ME"
grafana_password         = "CHANGE_ME"
slack_webhook_url        = "https://hooks.slack.com/services/TODO/REPLACE-WITH-YOUR-WEBHOOK"
